# Ship Server Configuration

# JWT signing key (generate with: openssl rand -base64 64)
JWT_SECRET=change-me-to-a-random-64-byte-string

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shipagent

# Google AI API key (for vector embeddings — optional, dev mode uses placeholders)
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=...

# Server
PORT=3847
HOST=0.0.0.0

# Allowed email domain for registration
ALLOWED_EMAIL_DOMAIN=harness.io
